#!/bin/bash

# db_pull: Download database files from a Google Drive folder to a local directory
# Usage: db_pull <drive_folder_id> <local_dir>
# Env:   GOG_ACCOUNT — Google account for gog CLI

set -e

echo "===========$(date)==========="
echo ""

DATA_DIR="$HOME/data"

files=$(gog drive ls --parent "$GOG_DRIVE_FOLDER_ID" --json --account "$GOG_ACCOUNT")
file_count=$(echo "$files" | jq '.files | length')

if [ "$file_count" -eq 0 ]; then
  echo "No files found in Drive folder $GOG_DRIVE_FOLDER_ID"
  exit 0
fi

echo "$files" | jq -c '.files[]' | while read -r file; do
  file_id=$(echo "$file" | jq -r '.id')
  file_name=$(echo "$file" | jq -r '.name')
  local_path="$DATA_DIR/$file_name"

  echo "🚀 Downloading $file_name..."
  gog drive download "$file_id" --output "$local_path" --account "$GOG_ACCOUNT"

  if [[ "$file_name" == *.db ]]; then
    result=$(sqlite3 "$local_path" "PRAGMA integrity_check;" 2>&1)
    if [ "$result" != "ok" ]; then
      echo "⚠️  Warning: integrity check failed for $file_name: $result" >&2
    else
      echo "✅ OK: $file_name integrity check passed"
    fi
  fi
  echo ""
done

echo "db_pull: complete"
