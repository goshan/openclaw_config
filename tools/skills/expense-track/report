#!/usr/bin/env bash
# report — Generate daily or monthly expense reports
# Usage: report daily|monthly
# Env:   SLACK_WEBHOOK_URL — if set, posts output to Slack instead of stdout

set -euo pipefail

MYSQL_OPTS="-h$MYSQL_HOST -P$MYSQL_PORT -u$MYSQL_USER -p$MYSQL_PASSWORD --default-character-set=utf8mb4 --skip-column-names --batch"

q() { mysql $MYSQL_OPTS expense -e "$1"; }

card_emoji() {
  case "$1" in
    Lexus*)   echo "🔵" ;;
    Amazon*)  echo "🟠" ;;
    PayPay*)  echo "🟢" ;;
    Cash*)    echo "🟣" ;;
    *)        echo "💳" ;;
  esac
}

daily_report() {
  local yesterday
  yesterday=$(q "SELECT CURDATE() - INTERVAL 1 DAY;")

  echo "💳 Daily Expense Report — ${yesterday}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  # Per-card details
  local cards
  cards=$(q "
    SELECT DISTINCT pm.name
    FROM transactions t
    JOIN payment_methods pm ON t.payment_method_id = pm.id
    WHERE t.date = CURDATE() - INTERVAL 1 DAY
    ORDER BY pm.id;
  ")

  if [ -z "$cards" ]; then
    echo "No expenses recorded yesterday. 🎉"
  else
    while IFS= read -r card; do
      local emoji
      emoji=$(card_emoji "$card")
      echo "${emoji} ${card}"

      while IFS=$'\t' read -r store amount category; do
        echo "  • ${store} — ${amount} (${category})"
      done < <(q "
        SELECT t.store, CONCAT('¥', FORMAT(t.amount, 0)), t.category
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date = CURDATE() - INTERVAL 1 DAY
          AND pm.name = '${card}'
        ORDER BY t.amount DESC;
      ")

      local subtotal
      subtotal=$(q "
        SELECT CONCAT('¥', FORMAT(COALESCE(SUM(t.amount), 0), 0))
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date = CURDATE() - INTERVAL 1 DAY
          AND pm.name = '${card}';
      ")
      echo "  Subtotal: ${subtotal}"
      echo
    done <<< "$cards"
  fi

  local yesterday_total
  yesterday_total=$(q "
    SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
    FROM transactions
    WHERE date = CURDATE() - INTERVAL 1 DAY;
  ")
  echo
  echo "💰 Yesterday Total: ${yesterday_total}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  # Month-to-date
  local month_name
  month_name=$(date +"%B")

  local month_grand
  month_grand=$(q "
    SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
    FROM transactions
    WHERE date >= DATE_FORMAT(CURDATE(), '%Y-%m-01');
  ")
  echo "📊 Month-to-Date (${month_name}): <http://dashboard.goshan.info/dashboard/3-expense?tab=6-month-to-date|${month_grand}>"
}

monthly_report() {
  local last_month_label
  last_month_label=$(q "SELECT DATE_FORMAT(CURDATE() - INTERVAL 1 MONTH, '%Y-%m');")
  local month_name
  month_name=$(date -j -f "%Y-%m" "$last_month_label" "+%B %Y" 2>/dev/null \
    || date -d "${last_month_label}-01" "+%B %Y" 2>/dev/null \
    || echo "$last_month_label")

  local grand_total
  grand_total=$(q "
    SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
    FROM transactions
    WHERE date >= DATE_FORMAT(CURDATE() - INTERVAL 1 MONTH, '%Y-%m-01')
      AND date < DATE_FORMAT(CURDATE(), '%Y-%m-01');
  ")
  echo "📊 Monthly Expense Report — ${month_name}: <http://dashboard.goshan.info/dashboard/3-expense?tab=8-last-month|${grand_total}>"
}

MODE="${1:-}"
if [[ "$MODE" != "daily" && "$MODE" != "monthly" ]]; then
  echo "Usage: report daily|monthly" >&2
  exit 1
fi

output=$("${MODE}_report")

if [ -n "${SLACK_WEBHOOK_URL:-}" ]; then
  payload=$(jq -n --arg text "$output" '{"text": $text}')
  curl -s -X POST -H 'Content-type: application/json' --data "$payload" "$SLACK_WEBHOOK_URL"
else
  echo "$output"
fi
