#!/usr/bin/env bash
# report — Generate daily or monthly expense reports
# Usage: report daily|monthly
# Env:   SLACK_WEBHOOK_URL — if set, posts output to Slack instead of stdout

set -euo pipefail

DB="$HOME/data/expense.db"

q() { sqlite3 "$DB" "$1"; }

card_emoji() {
  case "$1" in
    Lexus*)   echo "🔵" ;;
    Amazon*)  echo "🟠" ;;
    PayPay*)  echo "🟢" ;;
    Cash*)    echo "🟣" ;;
    *)        echo "💳" ;;
  esac
}

daily_report() {
  local yesterday
  yesterday=$(q "SELECT date('now', '-1 day', 'localtime');")

  echo "💳 Daily Expense Report — ${yesterday}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  # Per-card details
  local cards
  cards=$(q "
    SELECT DISTINCT pm.name
    FROM transactions t
    JOIN payment_methods pm ON t.payment_method_id = pm.id
    WHERE t.date = date('now', '-1 day', 'localtime')
    ORDER BY pm.id;
  ")

  if [ -z "$cards" ]; then
    echo "No expenses recorded yesterday. 🎉"
  else
    while IFS= read -r card; do
      local emoji
      emoji=$(card_emoji "$card")
      echo "${emoji} ${card}"

      while IFS='|' read -r store amount category; do
        echo "  • ${store} — ${amount} (${category})"
      done < <(q "
        SELECT t.store, printf('¥%,.0f', t.amount), t.category
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date = date('now', '-1 day', 'localtime')
          AND pm.name = '${card}'
        ORDER BY t.amount DESC;
      ")

      local subtotal
      subtotal=$(q "
        SELECT printf('¥%,.0f', COALESCE(SUM(t.amount), 0))
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date = date('now', '-1 day', 'localtime')
          AND pm.name = '${card}';
      ")
      echo "  Subtotal: ${subtotal}"
      echo
    done <<< "$cards"
  fi

  local yesterday_total
  yesterday_total=$(q "
    SELECT printf('¥%,.0f', COALESCE(SUM(amount), 0))
    FROM transactions
    WHERE date = date('now', '-1 day', 'localtime');
  ")
  echo
  echo "💰 Yesterday Total: ${yesterday_total}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  # Month-to-date
  local month_name
  month_name=$(date +"%B")

  local month_grand
  month_grand=$(q "
    SELECT printf('¥%,.0f', COALESCE(SUM(amount), 0))
    FROM transactions
    WHERE date >= date('now', 'start of month', 'localtime');
  ")
  echo "📊 Month-to-Date (${month_name}): [${month_grand}](http://dashboard.goshan.info/dashboard/3-expense?tab=6-month-to-date)"
}

monthly_report() {
  local last_month_label
  last_month_label=$(q "SELECT strftime('%Y-%m', date('now', 'start of month', '-1 month', 'localtime'));")
  local month_name
  month_name=$(date -j -f "%Y-%m" "$last_month_label" "+%B %Y" 2>/dev/null \
    || date -d "${last_month_label}-01" "+%B %Y" 2>/dev/null \
    || echo "$last_month_label")

  local grand_total
  grand_total=$(q "
    SELECT printf('¥%,.0f', COALESCE(SUM(amount), 0))
    FROM transactions
    WHERE date >= date('now', 'start of month', '-1 month', 'localtime')
      AND date < date('now', 'start of month', 'localtime');
  ")
  echo "📊 Monthly Expense Report — ${month_name}: [${grand_total}](http://dashboard.goshan.info/dashboard/3-expense?tab=8-last-month)"
}

MODE="${1:-}"
if [[ "$MODE" != "daily" && "$MODE" != "monthly" ]]; then
  echo "Usage: report daily|monthly" >&2
  exit 1
fi

output=$("${MODE}_report")

if [ -n "${SLACK_WEBHOOK_URL:-}" ]; then
  payload=$(jq -n --arg text "$output" '{"text": $text}')
  curl -s -X POST -H 'Content-type: application/json' --data "$payload" "$SLACK_WEBHOOK_URL"
else
  echo "$output"
fi
