#!/usr/bin/env python3
"""
expense_add: Insert a transaction record into the expenses database.
Usage: expense_add <payment_method_id> <date> <store> <amount> <category> <note> [--currency CODE]
  date:     'YYYY/MM/DD', 'YYYY-MM-DD', or either with ' HH:mm' — stored as YYYY-MM-DD
  currency: ISO 4217 currency code (default: JPY). If not JPY, amount is converted to JPY.
            Appends "original amount: CURRENCY RAW" to note automatically.
            If the rate fetch fails, stores the raw amount and marks note with "currency conversion failed".
Note: Database is `expense` on the configured MySQL server.
"""

import os
import sys
import json
import argparse
import urllib.request
from datetime import datetime

import mysql.connector

EXCHANGE_API = 'https://api.frankfurter.app/latest?from={}&to=JPY'


def parse_date(date_str):
    for fmt in ('%Y/%m/%d %H:%M', '%Y/%m/%d', '%Y-%m-%d %H:%M', '%Y-%m-%d'):
        try:
            return datetime.strptime(date_str.strip(), fmt).strftime('%Y-%m-%d')
        except ValueError:
            continue
    raise ValueError(f"Invalid date format: '{date_str}'. Expected 'YYYY/MM/DD' or 'YYYY-MM-DD' (with optional HH:mm).")


def fetch_rate(currency):
    try:
        url = EXCHANGE_API.format(currency)
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
            return data['rates']['JPY']
    except Exception:
        return None


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument('payment_method_id')
    parser.add_argument('date')
    parser.add_argument('store')
    parser.add_argument('amount')
    parser.add_argument('category')
    parser.add_argument('note')
    parser.add_argument('--currency', default='JPY', metavar='CODE',
                        help='ISO 4217 currency code (default: JPY)')
    args = parser.parse_args()

    try:
        date = parse_date(args.date)
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    try:
        amount_raw = float(args.amount)
    except ValueError:
        print(f"Error: amount must be a number, got '{args.amount}'.", file=sys.stderr)
        sys.exit(1)

    currency = args.currency.upper()
    note = args.note if args.note.upper() != 'NULL' else ''

    if currency == 'JPY':
        amount = round(amount_raw)
    else:
        rate = fetch_rate(currency)
        if rate is None:
            amount = amount_raw
            conversion_note = f"currency conversion failed (original: {currency} {amount_raw})"
        else:
            amount = round(amount_raw * rate)
            conversion_note = f"original amount: {currency} {amount_raw}"
        note = f"{note}; {conversion_note}" if note else conversion_note

    conn = None
    try:
        conn = mysql.connector.connect(
            host=os.environ['MYSQL_HOST'],
            port=int(os.environ.get('MYSQL_PORT', 3306)),
            user=os.environ['MYSQL_USER'],
            password=os.environ['MYSQL_PASSWORD'],
            database='expense',
            charset='utf8mb4',
        )
        cur = conn.cursor()
        cur.execute(
            "INSERT INTO transactions (payment_method_id, date, store, amount, category, note) VALUES (%s, %s, %s, %s, %s, %s)",
            (args.payment_method_id, date, args.store, amount, args.category, note or None)
        )
        conn.commit()
        print(f"Inserted transaction id={cur.lastrowid}: {args.store} ¥{amount} on {date}")
    except mysql.connector.Error as e:
        print(f"MySQL Error: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        if conn:
            conn.close()


if __name__ == '__main__':
    main()
