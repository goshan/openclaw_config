#!/usr/bin/env python3

"""
mysql_exec: Execute a parameterized MySQL query safely.
Usage: mysql_exec <database_name> <query> [arg1 arg2 ...]
    <query> uses `%s` as argument placeholder, example:
    'INSERT IGNORE INTO processed_emails (message_id, subject, sender, received_at) VALUES (%s, %s, %s, %s)'
    The number of remaining arguments must equal the number of `%s` in the query.

Connection is configured via environment variables:
    MYSQL_HOST, MYSQL_PORT, MYSQL_USER, MYSQL_PASSWORD
"""

import sys
import os
import mysql.connector

def main():
    if len(sys.argv) < 3:
        print(__doc__)
        sys.exit(1)

    db_name = sys.argv[1]
    query = sys.argv[2]
    params = sys.argv[3:]

    placeholder_count = query.count('%s')
    if placeholder_count != len(params):
        print(f"Error: Query expected {placeholder_count} argument(s), but got {len(params)}.", file=sys.stderr)
        sys.exit(1)

    conn = None
    try:
        conn = mysql.connector.connect(
            host=os.environ['MYSQL_HOST'],
            port=int(os.environ.get('MYSQL_PORT', 3306)),
            user=os.environ['MYSQL_USER'],
            password=os.environ['MYSQL_PASSWORD'],
            database=db_name,
            charset='utf8mb4',
        )
        cur = conn.cursor()
        cur.execute(query, params if params else None)
        if cur.description is not None:
            rows = cur.fetchall()
            for row in rows:
                print('\t'.join(str(c) if c is not None else '' for c in row))
        conn.commit()
    except mysql.connector.Error as e:
        print(f"MySQL Error: {e}", file=sys.stderr)
        sys.exit(1)
    except KeyError as e:
        print(f"Missing environment variable: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        if conn:
            conn.close()

if __name__ == "__main__":
    main()
