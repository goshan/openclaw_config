#!/usr/bin/env python3
"""
expense_add: Insert a transaction record into the expenses database.
Usage: expense_add <payment_method_id> <date> <store> <amount> <category> <note>
  date:     'YYYY/MM/DD', 'YYYY-MM-DD', or either with ' HH:mm' — stored as YYYY-MM-DD
"""

import sys
import sqlite3
from pathlib import Path
from datetime import datetime

DB_PATH = '/data/expense.db'


def parse_date(date_str):
    """Parse date in various formats and return 'YYYY-MM-DD'."""
    for fmt in ('%Y/%m/%d %H:%M', '%Y/%m/%d', '%Y-%m-%d %H:%M', '%Y-%m-%d'):
        try:
            return datetime.strptime(date_str.strip(), fmt).strftime('%Y-%m-%d')
        except ValueError:
            continue
    raise ValueError(f"Invalid date format: '{date_str}'. Expected 'YYYY/MM/DD' or 'YYYY-MM-DD' (with optional HH:mm).")


def main():
    if len(sys.argv) != 7:
        print(__doc__)
        sys.exit(1)

    payment_method_id, date_raw, store, amount_raw, category, note = sys.argv[1:]

    try:
        date = parse_date(date_raw)
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    try:
        amount = float(amount_raw)
    except ValueError:
        print(f"Error: amount must be a number, got '{amount_raw}'.", file=sys.stderr)
        sys.exit(1)

    conn = None
    try:
        conn = sqlite3.connect(DB_PATH)
        cur = conn.cursor()
        cur.execute(
            "INSERT INTO transactions (payment_method_id, date, store, amount, category, note) VALUES (?, ?, ?, ?, ?, ?)",
            (payment_method_id, date, store, amount, category, note)
        )
        conn.commit()
        print(f"Inserted transaction id={cur.lastrowid}: {store} {amount} on {date}")
    except sqlite3.Error as e:
        print(f"SQLite Error: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        if conn:
            conn.close()


if __name__ == '__main__':
    main()
